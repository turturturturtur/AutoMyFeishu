# ──────────────────────────────────────────────────────────────────
#  Feishu App credentials
#  Create your app at: https://open.feishu.cn/app
# ──────────────────────────────────────────────────────────────────
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
# Optional: only needed if webhook encryption is enabled in Feishu console
FEISHU_ENCRYPT_KEY=

# Bot's own open_id — used to validate @-mentions in group chats.
# Obtain via Feishu Open API: GET /open-apis/contact/v3/users/me
# Leave empty to rely on FEISHU_BOT_NAME for @-mention detection instead.
FEISHU_BOT_OPEN_ID=

# Bot display name in Feishu — used for @-mention detection when
# FEISHU_BOT_OPEN_ID is not set. Must match the bot's name exactly.
FEISHU_BOT_NAME=AutoMyFeishu

# ──────────────────────────────────────────────────────────────────
#  Feishu Bitable (multi-dimensional table used to record results)
#  Only APP_TOKEN is required. TABLE_ID is auto-discovered/created.
# ──────────────────────────────────────────────────────────────────
BITABLE_APP_TOKEN=your_bitable_app_token_here
# BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx  # optional: skip auto-discovery at startup

# ──────────────────────────────────────────────────────────────────
#  LLM Provider
#  "anthropic" (default) uses the Claude API.
#  "kimi" uses the Kimi / Moonshot AI API (OpenAI-compatible).
# ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic

# ──────────────────────────────────────────────────────────────────
#  Claude / Anthropic  (required when LLM_PROVIDER=anthropic)
# ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# Any Claude model name, or a compatible third-party model identifier.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Optional: override the base URL for proxy/mirror endpoints.
# Leave commented out to use the official Anthropic API (https://api.anthropic.com).
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# ──────────────────────────────────────────────────────────────────
#  Kimi / Moonshot AI  (required when LLM_PROVIDER=kimi)
# ──────────────────────────────────────────────────────────────────
KIMI_API_KEY=sk-your_kimi_key_here
KIMI_MODEL=moonshot-v1-32k
# Default public endpoint — change only if using a mirror or proxy.
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# ──────────────────────────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ──────────────────────────────────────────────────────────────────
#  Experiments directory
#  Each run creates its own exp_<uuid>/ subdirectory here.
# ──────────────────────────────────────────────────────────────────
EXPERIMENTS_DIR=./Experiments

# Maximum auto-repair retries when --retry N is not given on a command.
DEFAULT_MAX_RETRIES=5