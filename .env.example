# Feishu App credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=

# Feishu Bitable target
# Only APP_TOKEN is required. TABLE_ID is auto-discovered/created by ensure_experiment_table().
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxx
# BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx  # optional: set to skip the table lookup at startup

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Model name — use any Claude model, or a compatible third-party model name (e.g. glm-4).
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Optional: override the API base URL for mirror/proxy endpoints.
# Leave commented out to use the official Anthropic API (https://api.anthropic.com).
# Example for a proxy: ANTHROPIC_BASE_URL=https://your-proxy.example.com/v1
# ANTHROPIC_BASE_URL=

# Server
HOST=0.0.0.0
PORT=8080

# Workspace for generated scripts (each task gets its own subdirectory)
WORKSPACES_DIR=./workspaces
